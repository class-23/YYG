page{background:#fffaf6;color:#1a211d;font-family:-apple-system,BlinkMacSystemFont,PingFang SC,Microsoft YaHei,sans-serif;min-height:100vh}.page{padding:32rpx 28rpx 56rpx}.eyebrow{color:#c2641a;font-size:24rpx;font-weight:800;text-transform:uppercase}.h1{font-size:56rpx;font-weight:900;line-height:1.12;margin-top:18rpx}.h2{font-size:40rpx;font-weight:900;line-height:1.2}.muted{color:#7d6d63;font-size:28rpx;line-height:1.65}.card,.warm-card{border-radius:18rpx;box-shadow:0 18rpx 50rpx rgba(197,98,26,.08)}.card{background:#fff;border:2rpx solid #f4d7bd}.warm-card{background:linear-gradient(180deg,#fff5e9,#fff);border:2rpx solid #ffc78f}.btn{align-items:center;border-radius:16rpx;display:flex;font-size:30rpx;font-weight:900;justify-content:center;min-height:92rpx;padding:0 28rpx}.btn-primary{background:#ed8a2f;color:#fff}.btn-ghost{background:#fff;border:2rpx solid #f4d7bd;color:#c2641a}.tag{align-items:center;background:#fff0de;border-radius:999rpx;color:#c2641a;display:inline-flex;font-size:22rpx;font-weight:800;min-height:44rpx;padding:0 18rpx}.section-title{align-items:flex-end;display:flex;gap:24rpx;justify-content:space-between;margin:48rpx 0 22rpx}.grid-2{display:grid;gap:18rpx;grid-template-columns:repeat(2,1fr)}