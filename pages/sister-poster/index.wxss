.sister-poster-page{background:#f4eee8;min-height:100vh}.poster-card{background:linear-gradient(165deg,#fff9f3,#ffdcb9);border-radius:28rpx;box-shadow:0 22rpx 60rpx rgba(106,65,31,.16);min-height:980rpx;overflow:hidden;padding:48rpx 38rpx;position:relative}.poster-light{background:hsla(0,0%,100%,.7);border-radius:50%;height:300rpx;position:absolute;right:-90rpx;top:-100rpx;width:300rpx}.poster-brand{color:#c46a2a;font-size:24rpx;font-weight:900;position:relative}.poster-title{color:#222;font-size:66rpx;font-weight:900;line-height:1.18;margin-top:70rpx;position:relative;width:500rpx}.poster-copy{color:#5f4c3f;font-size:30rpx;line-height:1.6;margin-top:28rpx;width:520rpx}.poster-team{align-items:center;background:hsla(0,0%,100%,.82);border-radius:20rpx;display:flex;gap:18rpx;margin-top:48rpx;padding:22rpx}.poster-avatar{align-items:center;background:#e79445;border-radius:50%;color:#fff;display:flex;font-size:30rpx;font-weight:900;height:76rpx;justify-content:center;width:76rpx}.poster-team text{color:#7a6a5f;font-size:23rpx}.poster-team view view{color:#222;font-size:31rpx;font-weight:900;margin-top:6rpx}.poster-quote{color:#c46a2a;font-size:34rpx;font-weight:900;margin-top:36rpx}.poster-code{align-items:center;background:#fff;border-radius:22rpx;display:flex;gap:22rpx;margin-top:56rpx;padding:24rpx}.fake-qr{align-items:center;border:8rpx solid #222;color:#222;display:flex;font-size:22rpx;font-weight:900;height:150rpx;justify-content:center;width:150rpx}.poster-code text{color:#222;font-size:27rpx;font-weight:900}.poster-code view view{color:#c46a2a;font-size:24rpx;margin-top:12rpx}.poster-footer{color:#7a6a5f;font-size:24rpx;margin-top:36rpx;text-align:center}.sister-poster-page > .btn{margin-top:24rpx}.unlock-note{margin-top:24rpx;padding:24rpx}.unlock-note text{color:#c46a2a;font-size:24rpx;font-weight:900}.unlock-note view{color:#6e5f55;font-size:25rpx;line-height:1.58;margin-top:10rpx}
