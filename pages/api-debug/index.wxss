.container {
  padding: 24rpx;
  background: #fffaf6;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #d56d1c;
}
.kv {
  display: flex;
  padding: 8rpx 0;
  font-size: 26rpx;
  align-items: flex-start;
}
.k {
  color: #8a7568;
  width: 160rpx;
  flex-shrink: 0;
}
.v {
  color: #333;
  word-break: break-all;
  flex: 1;
  font-family: monospace;
}
.device-id { color: #d56d1c; }
.ok { color: #2c9a4a; font-weight: bold; }
.err { color: #d9534f; font-weight: bold; }
.btn-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.btn-group button {
  margin: 0;
}
.code {
  background: #f6f6f6;
  padding: 16rpx;
  border-radius: 8rpx;
  font-family: monospace;
  font-size: 24rpx;
  word-break: break-all;
  white-space: pre-wrap;
  max-height: 600rpx;
  overflow: auto;
}
.log {
  font-family: monospace;
  font-size: 24rpx;
  padding: 6rpx 0;
  color: #555;
  word-break: break-all;
  border-bottom: 1rpx solid #f0f0f0;
}
.log.empty {
  color: #999;
  font-style: italic;
  border-bottom: none;
}
