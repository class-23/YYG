.intro{margin-top:18rpx}.signup-list{display:grid;gap:24rpx;margin-top:34rpx}.signup-card{background:#fff;border:2rpx solid #f4d7bd;border-radius:18rpx;padding:30rpx}.signup-card.active{background:#fff5e9;border-color:#ed8a2f}.signup-head{align-items:center;display:flex;justify-content:space-between}.check{color:#c2641a;font-size:24rpx;font-weight:900}.plan-name{font-size:40rpx;font-weight:900;margin-top:22rpx}.price{color:#c2641a;font-size:30rpx;font-weight:900;margin-top:20rpx}.benefits{color:#7d6d63;display:grid;font-size:27rpx;gap:12rpx;line-height:1.5;margin:24rpx 0}.actions{display:grid;gap:16rpx;grid-template-columns:1fr 1fr}.bottom-card{display:grid;gap:18rpx;margin-top:34rpx;padding:30rpx}