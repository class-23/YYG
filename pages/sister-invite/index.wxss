.invite-page{background:#fff9f3;min-height:100vh}.invite-hero{background:linear-gradient(145deg,#fff,#ffe8d2);border-radius:24rpx;padding:40rpx 30rpx;text-align:center}.inviter-avatar{align-items:center;background:#e79445;border:8rpx solid #fff;border-radius:50%;box-shadow:0 12rpx 32rpx rgba(196,106,42,.2);color:#fff;display:flex;font-size:42rpx;font-weight:900;height:112rpx;justify-content:center;margin:0 auto 20rpx;width:112rpx}.invite-hero .h1{font-size:42rpx}.invite-copy{color:#7a6a5f;font-size:27rpx;line-height:1.55;margin-top:18rpx}.first-task,.invalid-card,.invite-team{border-radius:24rpx;margin-top:24rpx;padding:30rpx}.first-task .h2,.invite-team .h2{margin-top:12rpx}.team-goal{color:#7a6a5f;font-size:25rpx;margin-top:12rpx}.invite-stats{display:grid;gap:12rpx;grid-template-columns:repeat(3,1fr);margin-top:24rpx}.invite-stats > view{background:#fff7ef;border-radius:15rpx;padding:20rpx 8rpx;text-align:center}.invite-stats text{color:#c46a2a;font-size:30rpx;font-weight:900}.invite-stats view view{color:#7a6a5f;font-size:20rpx;margin-top:6rpx}.first-task .muted{margin-top:14rpx}.task-options{display:flex;flex-wrap:wrap;gap:11rpx;margin-top:20rpx}.task-options text{background:#fff;border-radius:999rpx;color:#c46a2a;font-size:22rpx;font-weight:800;padding:12rpx 16rpx}.main-action{margin-top:26rpx}.invite-page > .btn-ghost{margin-top:14rpx}.invite-rule{color:#9b8a7f;font-size:21rpx;line-height:1.5;margin:16rpx 16rpx 0;text-align:center}.invalid-card{margin-top:140rpx;text-align:center}.invalid-card .btn,.invalid-card .muted{margin-top:24rpx}