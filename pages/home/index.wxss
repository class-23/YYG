.intro-hero{background:linear-gradient(135deg,#fff4e5,#e9a33f);border-radius:18rpx;color:#1a211d;min-height:238rpx;overflow:hidden;padding:18rpx;position:relative}
.intro-hero::after{background:linear-gradient(90deg,#fff,hsla(0,0%,100%,.96) 54%,hsla(0,0%,100%,.55) 72%,hsla(0,0%,100%,0));content:"";inset:0;position:absolute}
.hero-portrait{bottom:0;height:244rpx;position:absolute;right:0;width:206rpx;z-index:0}
.hero-content{background:linear-gradient(90deg,#fff,hsla(0,0%,100%,.94) 78%,hsla(0,0%,100%,.58));border-radius:16rpx;min-width:0;padding:18rpx 20rpx;position:relative;width:430rpx;z-index:1}
.intro-hero .eyebrow{color:#b66020}
.intro-hero .h1{font-size:36rpx;line-height:1.2;margin-top:10rpx}
.hero-copy{color:#4f4138;font-size:23rpx;font-weight:700;line-height:1.4;margin-top:10rpx}
.hero-proof{display:flex;flex-wrap:wrap;gap:0;margin-top:12rpx}
.hero-proof text{border-right:2rpx solid rgba(182,96,32,.25);color:#b66020;font-size:20rpx;font-weight:900;margin-right:12rpx;padding-right:12rpx}
.hero-proof text:last-child{border-right:0;margin-right:0;padding-right:0}
.module-section{display:grid;gap:22rpx;margin-top:22rpx}
.module-card{align-items:center;display:grid;gap:20rpx;grid-template-columns:1fr 178rpx;min-height:250rpx;padding:30rpx}
.module-mom{border-color:#ed8a2f}
.module-child{background:#fff;border-color:#ed8a2f}
.module-title{color:#1a211d;font-size:40rpx;font-weight:900;margin-top:14rpx}
.module-copy{color:#7d6d63;font-size:26rpx;line-height:1.55;margin-top:14rpx}
.sister-entry{align-items:center;background:linear-gradient(135deg,#fff,#fff0e2);border:2rpx solid #f0b36e;border-radius:20rpx;box-shadow:0 16rpx 40rpx rgba(196,106,42,.08);display:grid;gap:16rpx;grid-template-columns:118rpx 1fr 36rpx;margin-top:24rpx;padding:24rpx}
.sister-entry-avatars{display:flex;padding-left:26rpx}
.sister-entry-avatars text{align-items:center;background:#e79445;border:4rpx solid #fff;border-radius:50%;color:#fff;display:flex;font-size:21rpx;font-weight:900;height:54rpx;justify-content:center;margin-left:-24rpx;width:54rpx}
.sister-entry-title{color:#222;font-size:32rpx;font-weight:900;margin-top:6rpx}
.sister-entry-copy > view:last-child{color:#7a6a5f;font-size:22rpx;margin-top:5rpx}
.sister-entry-arrow{color:#c46a2a;font-size:52rpx;font-weight:300}
.listen-card{background:#fff;border-radius:18rpx;box-shadow:inset 0 0 0 2rpx #f4d7bd;margin-top:28rpx;padding:30rpx;position:relative}
.listen-card:active{transform:scale(.992)}
.player-top{align-items:center;color:#7d6d63;display:flex;font-size:24rpx;font-weight:800;gap:14rpx}
.player-top text{background:#ed8a2f;border-radius:50%;height:18rpx;width:18rpx}
.quote{color:#1a211d;font-family:Georgia,serif;font-size:34rpx;font-weight:900;line-height:1.32;margin-top:18rpx}
.waveform{align-items:flex-end;display:flex;gap:8rpx;height:56rpx;margin-top:22rpx}
.waveform text{background:#ed8a2f;border-radius:999rpx;width:12rpx}
.waveform text:nth-child(1),.waveform text:nth-child(5),.waveform text:nth-child(8){height:24rpx}
.waveform text:nth-child(10),.waveform text:nth-child(2),.waveform text:nth-child(6){height:42rpx}
.waveform text:nth-child(3),.waveform text:nth-child(7){height:54rpx}
.waveform text:nth-child(4),.waveform text:nth-child(9){height:32rpx}
.listen-hint{color:#c46a2a;font-size:22rpx;font-weight:900;line-height:1.35;margin-top:18rpx}
