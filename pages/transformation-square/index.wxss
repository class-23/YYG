.square-page{background:#fff9f3;min-height:100vh}.square-hero{background:radial-gradient(circle at 92% 10%,hsla(0,0%,100%,.85) 0 72rpx,transparent 74rpx),linear-gradient(135deg,#fff7ef,#ffe3c5);border:2rpx solid #f0b36e;border-radius:24rpx;padding:36rpx 30rpx}.square-sub{color:#5f4c3f;font-size:28rpx;font-weight:800;line-height:1.5;margin-top:16rpx}.connection-points,.square-tags{display:flex;flex-wrap:wrap;gap:10rpx;margin-top:18rpx}.connection-points text,.square-tags text{background:hsla(0,0%,100%,.82);border-radius:999rpx;color:#c46a2a;font-size:21rpx;font-weight:800;padding:9rpx 14rpx}.social-entry{border-radius:24rpx;box-shadow:0 18rpx 46rpx rgba(104,67,38,.08);margin-top:22rpx;padding:28rpx}.sister-social{background:linear-gradient(145deg,#fff,#fff0e2);border:2rpx solid #e79445}.connection-social{background:linear-gradient(145deg,#fff,#f8eee8);border:2rpx solid #e2c5b0}.entry-main{display:grid;gap:18rpx;grid-template-columns:76rpx 1fr}.entry-icon{align-items:center;border-radius:22rpx;color:#fff;display:flex;font-size:30rpx;font-weight:900;height:76rpx;justify-content:center;width:76rpx}.sister-icon{background:#e79445}.connection-icon{background:#9f6e5a}.entry-label{color:#c46a2a;font-size:21rpx;font-weight:900}.entry-title{color:#222;font-size:34rpx;font-weight:900;margin-top:5rpx}.entry-copy{color:#7a6a5f;font-size:23rpx;line-height:1.5;margin-top:9rpx}.entry-status{background:#fff;border-radius:14rpx;color:#7a6a5f;font-size:22rpx;margin-top:20rpx;padding:16rpx}.entry-button{background:#e79445;border-radius:15rpx;color:#fff;font-size:26rpx;font-weight:900;margin-top:18rpx}.entry-button.secondary{background:#9f6e5a}.square-section-title{align-items:flex-end;display:flex;gap:18rpx;justify-content:space-between;margin:36rpx 0 16rpx}.safe-note{color:#9b8a7f;font-size:20rpx}.moment-list{display:grid;gap:14rpx}.moment-card{display:grid;gap:16rpx;grid-template-columns:64rpx 1fr;padding:22rpx}.moment-avatar{align-items:center;background:#fff0e2;border-radius:50%;color:#c46a2a;display:flex;font-size:25rpx;font-weight:900;height:64rpx;justify-content:center;width:64rpx}.moment-top{align-items:center;display:flex;gap:12rpx;justify-content:space-between}.moment-top text:first-child{color:#222;font-size:25rpx;font-weight:900}.moment-top text:last-child{color:#c46a2a;font-size:20rpx}.moment-content > view:last-child{color:#7a6a5f;font-size:23rpx;line-height:1.5;margin-top:8rpx}.square-rule{background:#f2ebe5;border-radius:14rpx;color:#8d7a6d;font-size:20rpx;line-height:1.5;margin-top:18rpx;padding:18rpx;text-align:center}