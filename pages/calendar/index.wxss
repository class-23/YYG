.intro{margin-top:18rpx}.calendar-card{margin-top:30rpx;padding:24rpx}.calendar-grid{display:grid;gap:12rpx;grid-template-columns:repeat(7,1fr)}.day{align-items:center;background:#eee7e1;border-radius:14rpx;color:#8a7568;display:flex;flex-direction:column;justify-content:center;min-height:76rpx}.day.done{background:#ed8a2f;color:#fff}.day.special{background:#fff0de;border:2rpx solid #ffc78f;color:#c2641a;min-height:108rpx}.day text{font-size:28rpx;font-weight:900}.day view{font-size:18rpx;font-weight:800;margin-top:4rpx;text-align:center}.badge-list{display:grid;gap:16rpx}.badge{align-items:center;background:#eee7e1;border-radius:16rpx;color:#8a7568;display:flex;justify-content:space-between;padding:24rpx}.badge.unlocked{background:#fff0de;color:#c2641a}.badge text,.badge view{font-size:28rpx;font-weight:900}