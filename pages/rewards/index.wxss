.intro{margin-top:18rpx}.cash-summary{align-items:center;background:linear-gradient(135deg,#fff7ef,#ffe5c9);border:2rpx solid #f0b36e;border-radius:22rpx;display:grid;gap:18rpx;grid-template-columns:1fr 150rpx;margin-top:28rpx;padding:30rpx}.cash-summary text{color:#c2641a;font-size:23rpx;font-weight:900}.cash-summary > view > view{color:#222;font-family:Georgia,serif;font-size:66rpx;font-weight:900;margin:6rpx 0}.cash-summary button{background:#fff;border-radius:14rpx;color:#c46a2a;font-size:23rpx;font-weight:900}.benefit-stats{display:grid;gap:12rpx;grid-template-columns:repeat(3,1fr);margin-top:16rpx}.benefit-stats > view{background:#fff;border:2rpx solid #f4d7bd;border-radius:15rpx;padding:20rpx 10rpx;text-align:center}.benefit-stats text{color:#c2641a;font-size:28rpx;font-weight:900}.benefit-stats view view{color:#7d6d63;font-size:20rpx;margin-top:5rpx}.badge-list,.reward-list{display:grid;gap:18rpx;margin-top:30rpx}.compact-title{margin-top:34rpx}.compact-list{margin-top:0}.badge,.reward{align-items:center;display:flex;justify-content:space-between;padding:28rpx}.badge text,.reward text{color:#1a211d;font-size:30rpx;font-weight:900}.badge view,.reward view{color:#c2641a;font-size:27rpx;font-weight:900}.badge{background:#eee7e1;border-radius:16rpx}.badge.unlocked{background:#fff0de}.sister-reward{align-items:center;background:linear-gradient(135deg,#fff,#fff0e2);border-color:#f0b36e;display:grid;gap:18rpx;grid-template-columns:1fr 160rpx;margin-top:26rpx;padding:28rpx}.sister-reward.is-unlocked{box-shadow:0 16rpx 40rpx rgba(231,148,69,.16)}.sister-reward-title{color:#222;font-size:32rpx;font-weight:900;margin-top:10rpx}.sister-reward-copy{color:#7a6a5f;font-size:22rpx;line-height:1.45;margin-top:9rpx}.sister-reward button{background:#e79445;border-radius:14rpx;color:#fff;font-size:24rpx;font-weight:900}.btn{margin-top:30rpx}.cash-rule{background:#fff5e9;border-radius:16rpx;margin-top:20rpx;padding:22rpx}.cash-rule text{color:#c2641a;font-size:24rpx;font-weight:900}.cash-rule view{color:#7d6d63;font-size:22rpx;line-height:1.5;margin-top:8rpx}